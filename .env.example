VITE_API_BASE_URL=https://your-api-url.example.com

# Optional — Cloudflare Web Analytics beacon token.
# Leave blank to build without analytics (no external script loaded).
# Get yours at: Cloudflare dashboard → Analytics & Logs → Web Analytics → Add a site (manual / JS snippet mode)
# VITE_CF_BEACON_TOKEN=your-32-char-hex-token

# Optional — Google Tag Manager container ID (e.g. GTM-XXXXXXX).
# When set, build will inject the GTM head/body snippets into dist/index.html.
# Leave blank in dev/preview/CI builds to avoid sending traffic to GA.
# VITE_GTM_ID=GTM-XXXXXXX
